APP_NAME=Octopus Ops MVP
ENV=dev
LOG_LEVEL=INFO

# SQLite file path (relative or absolute)
SQLITE_PATH=./data/octopus.db

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Default admin bootstrap (created on first start if DB empty)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123

# 智能体 AI 服务（仅 docker compose -f docker-compose.agent.yml 时需要）
DASHSCOPE_API_KEY=your_dashscope_api_key_here
